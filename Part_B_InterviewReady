#  Q3 — Debug is_prime
# ════════════════════════════════════════════════════════════

print("=" * 55)
print("Q3: Debug is_prime")
print("=" * 55)

print("""
ORIGINAL CODE:
--------------
  def is_prime(n):
      if n < 2:
          return False
      for i in range(2, n):      ← BUG HERE
          if n % i == 0:
              return False
      return True

BUG 1 — PERFORMANCE (O(n) instead of O(√n)):
  range(2, n) checks ALL numbers up to n-1.
  We only need to check up to √n.
  WHY: if n has a factor larger than √n, its paired factor
       must be smaller than √n — so we'd have caught it already.
  Fix: range(2, int(n**0.5) + 1)

  Impact: for n=1,000,000 the buggy version does ~1,000,000
  iterations; the fix does only ~1,000 iterations (1000× faster).

BUG 2 — LOGIC (missing special cases):
  n=1  → correctly returns False (n < 2 check handles it)
  n=2  → range(2, 2) is EMPTY → loop never runs → returns True ✓
  n=4  → range(2, 4) = [2,3] → 4%2==0 → False ✓  (works but slow)
  The logic is not wrong, just wildly inefficient.

NO BUG in the base case (n < 2 → False) — that's correct.
""")


# -- Buggy version (for demonstration) --
def is_prime_buggy(n):
    if n < 2:
        return False
    for i in range(2, n):          # O(n) — checks every number up to n
        if n % i == 0:
            return False
    return True


# -- Fixed version --
def is_prime_fixed(n):
    """
    O(√n) primality check.
    Only checks divisors up to √n — mathematically sufficient.
    """
    if n < 2:
        return False
    if n == 2:
        return True                # 2 is the only even prime
    if n % 2 == 0:
        return False               # eliminate all even numbers early
    i = 3
    while i * i <= n:             # while loop: i goes up to √n only
        if n % i == 0:
            return False
        i += 2                     # skip even divisors (already eliminated)
    return True


# -- Verify both give same answers --
print("  Verification (buggy vs fixed):")
test_values = [0, 1, 2, 3, 4, 13, 17, 25, 97, 100]
print(f"  {'n':>5}  {'buggy':>8}  {'fixed':>8}  {'match':>6}")
print("  " + "-" * 35)
for n in test_values:
    b = is_prime_buggy(n)
    f = is_prime_fixed(n)
    match = "✓" if b == f else "✗ MISMATCH"
    print(f"  {n:>5}  {str(b):>8}  {str(f):>8}  {match:>6}")
