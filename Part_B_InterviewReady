#  Q2 — find_pairs: O(n²) then O(n)
# ════════════════════════════════════════════════════════════

print("\n" + "=" * 55)
print("Q2: find_pairs — O(n²) → O(n)")
print("=" * 55)


# ── Approach 1: O(n²) nested loops ───────────────────────────

def find_pairs_n2(numbers: list, target: int) -> list:
    """
    O(n²) — check every possible pair with nested loops.
    Outer loop picks first element, inner loop picks second.
    Avoid duplicates: inner loop starts at i+1.

    Time  complexity: O(n²)  — two nested loops over n elements
    Space complexity: O(k)   — k = number of valid pairs
    """
    pairs = []
    for i in range(len(numbers)):           # outer loop: O(n)
        for j in range(i + 1, len(numbers)):  # inner loop: O(n)
            if numbers[i] + numbers[j] == target:
                pairs.append((numbers[i], numbers[j]))
    return pairs


# ── Approach 2: O(n) using a set ─────────────────────────────

def find_pairs_n1(numbers: list, target: int) -> list:
    """
    O(n) — for each number, check if its complement is in a set.
    complement = target - current_number

    Why O(n)?
      Set lookup (`in`) is O(1) average.
      We loop once → O(n) × O(1) = O(n) total.

    Time  complexity: O(n)
    Space complexity: O(n) — we store seen numbers in a set
    """
    seen  = set()
    pairs = []
    for num in numbers:                     # single loop: O(n)
        complement = target - num
        if complement in seen:              # set lookup: O(1)
            pairs.append((complement, num))
        seen.add(num)
    return pairs


# ── Test both ────────────────────────────────────────────────
test_nums   = [1, 2, 3, 4, 5]
test_target = 6

r1 = find_pairs_n2(test_nums, test_target)
r2 = find_pairs_n1(test_nums, test_target)

print(f"\n  Input : {test_nums}, target = {test_target}")
print(f"  O(n²) : {r1}")
print(f"  O(n)  : {r2}")

# More edge cases
print(f"\n  find_pairs([1,1,1], 2)        O(n²): {find_pairs_n2([1,1,1], 2)}")
print(f"  find_pairs([1,1,1], 2)        O(n) : {find_pairs_n1([1,1,1], 2)}")
print(f"  find_pairs([], 5)             O(n²): {find_pairs_n2([], 5)}")
print(f"  find_pairs([3], 6)            O(n²): {find_pairs_n2([3], 6)}")

print("""
COMPLEXITY EXPLAINED:
  O(n²): for every element we scan all remaining elements.
          With n=1000, that's ~500,000 comparisons.

  O(n) : for every element we do ONE set lookup (O(1)).
          With n=1000, that's exactly 1,000 operations.

  Trade-off: O(n) uses extra memory (the `seen` set).
             O(n²) uses no extra memory but is much slower.
""")


