# ════════════════════════════════════════════════════════════
#  Q1 — break vs continue  +  loop-else
# ════════════════════════════════════════════════════════════

print("=" * 55)
print("Q1: break vs continue  +  loop-else")
print("=" * 55)

"""
BREAK
-----
Immediately exits the entire loop.
Remaining iterations are skipped.
Use when: you found what you needed and further looping is pointless.

CONTINUE
--------
Skips the REST of the current iteration only.
The loop continues with the next item.
Use when: you want to skip one item but keep looping.
"""

# -- break example --
print("\n--- break: stop at first even number ---")
numbers = [1, 3, 5, 4, 7, 9]
for n in numbers:
    if n % 2 == 0:
        print(f"  Found even: {n} → breaking out")
        break                       # exits the for loop entirely
    print(f"  {n} is odd, checking next...")

# -- continue example --
print("\n--- continue: skip odd numbers, print evens ---")
for n in range(1, 8):
    if n % 2 != 0:
        continue                    # skip this iteration, go to next n
    print(f"  Even: {n}")

"""
LOOP-ELSE
---------
The `else` block on a for/while loop runs ONLY IF the loop
completed without hitting a `break`.

If break fired → else is SKIPPED.
If loop ran to completion → else runs.

Classic use case: search patterns
  - If item found  → break (else skipped → "not found" message avoided)
  - If item absent → loop finishes, else runs → "not found" message shown
"""

print("\n--- loop-else: search pattern ---")

def search(items, target):
    for item in items:
        if item == target:
            print(f"  Found '{target}' ✓")
            break                   # found → else will NOT run
    else:
        # only runs if break was never hit
        print(f"  '{target}' not found in list")

search([10, 20, 30, 40], 30)   # → Found
search([10, 20, 30, 40], 99)   # → Not found


